    "from scipy.fft import fft\n",
    "\n",
    "def get_fft_features(sequence_data):\n",
    "    \"\"\"\n",
    "    Applies Fast Fourier Transform (FFT) to a sequence of sensor readings\n",
    "    to extract frequency domain features.\n",
    "    \n",
    "    Args:\n",
    "        sequence_data (np.array): A 2D array of shape (Time_Steps, Features).\n",
    "        \n",
    "    Returns:\n",
    "        np.array: A 1D array containing the magnitude of the FFT components.\n",
    "    \"\"\"\n",
    "    # Apply FFT along the time axis (axis 0)\n",
    "    fft_values = fft(sequence_data, axis=0)\n",
    "    \n",
    "    # Compute the magnitude (absolute value) of the FFT\n",
    "    fft_magnitude = np.abs(fft_values)\n",
    "    \n",
    "    # Flatten to a single vector as expected by the MLP model\n",
    "    return fft_magnitude.flatten()\n",
    "\n",
    "def get_tof_image_features(tof_row_data):\n",
    "    \"\"\"\n",
    "    Reshapes a flat array of 64 TOF features into an 8x8 matrix.\n",
    "    \n",
    "    Args:\n",
    "        tof_row_data (np.array): A flat 1D array of 64 TOF readings.\n",
    "        \n",
    "    Returns:\n",
    "        np.array: A 2D array of shape (8, 8).\n",
    "    \"\"\"\n",
    "    # Ensure the input is a numpy array\n",
    "    tof_array = np.array(tof_row_data)\n",
    "    \n",
    "    # Reshape to 8x8\n",
    "    return tof_array.reshape(8, 8)\n",
    "\n",
    "# --- Verification Step ---\n",
    "# Let's test these functions on a single example sequence to ensure shapes are correct.\n",
    "\n",
    "# 1. Select one sequence\n",
    "example_seq_id = train_df['sequence_id'].unique()[0]\n",
    "example_seq = train_df[train_df['sequence_id'] == example_seq_id]\n",
    "\n",
    "# 2. Identify feature columns (IMU/Thermopile vs TOF)\n",
    "tof_cols = [c for c in feature_cols if \"tof\" in c.lower()]\n",
    "imu_thm_cols = [c for c in feature_cols if \"tof\" not in c.lower()]\n",
    "\n",
    "# 3. Test FFT on IMU/Thermopile data\n",
    "example_imu_data = example_seq[imu_thm_cols].values\n",
    "fft_result = get_fft_features(example_imu_data)\n",
    "\n",
    "# 4. Test Reshaping on a single row of TOF data\n",
    "example_tof_row = example_seq[tof_cols].iloc[0].values\n",
    "tof_image = get_tof_image_features(example_tof_row)\n",
    "\n",
    "print(f\"Original Sequence Shape: {example_imu_data.shape}\")\n",
    "print(f\"FFT Feature Vector Shape: {fft_result.shape}\")\n",
    "print(f\"Original TOF Row Shape: {example_tof_row.shape}\")\n",
    "print(f\"Reshaped TOF Image Shape: {tof_image.shape}\")"
   ]
  },
